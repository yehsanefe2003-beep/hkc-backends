<configuration>
  <system.webServer>
    <!-- Node.js uygulamasını iisnode modülü ile çalıştır -->
    <handlers>
      <add name="iisnode" path="index.js" verb="*" modules="iisnode" />
    </handlers>
    
    <rewrite>
      <rules>
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^index.js\/debug[\/]?" />
        </rule>
        <!-- Geri kalan tüm istekleri index.js içerisindeki express/node servisine yönlendir -->
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True" />
          </conditions>
          <action type="Rewrite" url="index.js" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin"/>
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- index.js ve web.config değiştiğinde Node motorunu yeniden başlat -->
    <iisnode watchedFiles="web.config;*.js" />
    
  </system.webServer>
</configuration>
